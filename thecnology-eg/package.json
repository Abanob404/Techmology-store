{
  "name": "technology-store",
  "version": "1.0.0",
  "description": "Technology Store web application",
  "scripts": {
    "dev:server": "cd server && npm run dev",
    "dev": "npm run dev:server",
    "install:all": "npm install && cd server && npm install",
    "build:css": "tailwindcss -i ./input.css -o ./style.css --minify",
    "watch:css": "tailwindcss -i ./input.css -o ./style.css --watch"
  },
  "dependencies": {
    "cloudinary": "^2.10.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-fileupload": "^1.5.2",
    "mongoose": "^9.7.1",
    "serverless-http": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.7",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4"
  }
}
